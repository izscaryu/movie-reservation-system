# Copy this file to ".env" and adjust values. ".env" is gitignored.
# docker-compose reads .env automatically. To pass these to the Spring app
# (when running outside Docker), set them as real environment variables, or
# use an IntelliJ run-config / a tool like direnv.

# Database name created on first MySQL startup
DB_NAME=movie_reservation

# Application DB user (NOT root) used by the Spring app
DB_USERNAME=movieuser
DB_PASSWORD=moviepass

# MySQL root password (used by docker-compose healthcheck / admin tasks)
DB_ROOT_PASSWORD=rootpass

# Connection coordinates for the Spring app
DB_HOST=localhost
DB_PORT=3306

# Spring Boot HTTP port
SERVER_PORT=8080

# Seed admin user (created on first startup, hashed at runtime)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator
