# ---------------------------------------------------------------------------
# This file is OPTIONAL.
#
#   `docker compose up`  needs NO .env — the compose file ships safe dev
#                         defaults for everything and runs the app + DB.
#
#   You only need a .env for LOCAL IDE DEV, i.e. running the Spring app on
#   your host (mvnw / IntelliJ) against the MySQL container:
#       cp .env.example .env     # then `docker compose up -d mysql`
#
# docker-compose reads .env automatically. To pass these to a host-run Spring
# app, set them as real environment variables or use an IntelliJ run-config.
# ---------------------------------------------------------------------------

# Database name / credentials. Used by BOTH the mysql container (to initialise)
# and the app, so keep them consistent. Override here to change both at once.
DB_NAME=movie_reservation
DB_USERNAME=movieuser
DB_PASSWORD=moviepass

# MySQL root password (used by the compose healthcheck / admin tasks).
DB_ROOT_PASSWORD=rootpass

# Host port the dockerized MySQL is published on, for a DB client or a
# host-run app. Defaults to 3307 because host 3306 is often taken by a native
# MySQL install. This is the HOST side only — inside compose the app always
# talks to MySQL on the internal port 3306 regardless of this value.
DB_HOST_PORT=3307

# Connection coordinates for a HOST-RUN Spring app (not the dockerized one).
# Point at the published MySQL above. The app IN compose ignores these and
# uses the service name `mysql` on 3306 (set directly in docker-compose.yml).
DB_HOST=localhost
DB_PORT=3307

# Host port the app is published on (compose). Defaults to 8080.
APP_PORT=8080
SERVER_PORT=8080

# Seed admin user (created on first startup, hashed at runtime).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator

# JWT signing. The default in application.yml / docker-compose.yml is DEV-ONLY
# and INSECURE. Generate a real secret for any non-local use, e.g.:
#   openssl rand -base64 48
# Must be at least 32 bytes (256 bits) for HS256.
JWT_SECRET=dev-only-insecure-secret-change-me-0123456789-abcdefghijklmnop
# Access-token lifetime in milliseconds (default 1 hour).
JWT_EXPIRATION_MS=3600000
